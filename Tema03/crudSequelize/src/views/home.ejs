<!DOCTYPE html>
<html>

<head>
    <title>
        <%= title %>
    </title>
    <link rel="stylesheet" href="/public/css/styles.css">
</head>

<body>
    <h1>--CRUD SEQUELIZE CON NODE--</h1>
    <a href="/users">Ver usuarios</a>

    <h1>Lista de Usuarios</h1>
    <ul>
        <% users.forEach(user=> { %>
            <li>
                <%= user.nombre %> <a href="/updateUser/<%= user.id %>">edit</a> | <a href="/delete/<%= user.id %>">delete</a>
            </li>
            <% }) %>
    </ul>
    <form action="/createUser" method="POST">
        <label for="">Nombre 
            <input type="text" name="name">
        </label>
        <button>Guardar</button>        
    </form>
    
</body>

</html>